// Poultry360 - Fixed Database Schema
// PostgreSQL with Prisma

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ==================== ENUMS ====================

enum UserRole {
  OWNER
  MANAGER
}

enum BatchStatus {
  ACTIVE
  COMPLETED
  // CANCELLED
}

enum TransactionType {
  PURCHASE
  SALE
  PAYMENT
  RECEIPT
  ADJUSTMENT
  OPENING_BALANCE
  USAGE
}

enum NotificationType {
  LOW_INVENTORY
  VACCINATION_DUE
  BATCH_COMPLETION
  PAYMENT_DUE
  MORTALITY_ALERT
}

enum NotificationStatus {
  PENDING
  READ
  DISMISSED
}

enum VaccinationStatus {
  PENDING
  COMPLETED
  MISSED
  OVERDUE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ==================== CORE MODELS ====================
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  name      String  //name of the user 
  
  companyName String? //name of the company
  CompanyFarmLocation String? // Province + Location 
  CompanyFarmNumber Int?
  CompanyFarmCapacity Int?
 


  password  String  

  role      UserRole @default(OWNER)  
  gender    Gender   @default(MALE) //rm 
  status    UserStatus @default(PENDING_VERIFICATION)
  // Relationships
  // Farms this user owns
  ownedFarms Farm[]


  // Farms this user manages
  managedFarms Farm[] @relation("FarmManagers")


  customers Customer[]
  notifications Notification[]
  auditLogs AuditLog[]

  
  // Categories (unified)
  categories Category[]
  
  // Suppliers (simplified - no balance fields)
  dealers   Dealer[]
  hatcheries Hatchery[]
  medicineSuppliers MedicineSupplier[]
  
  // Inventory
  inventoryItems InventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Farm {
  id          String   @id @default(cuid())
  name        String

  capacity    Int
  description String?
  
  // Relationships
  // Owner (one-to-many)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Managers (many-to-many)
  managers    User[]   @relation("FarmManagers")

  batches     Batch[]
  expenses    Expense[]
  sales       Sale[]
  inventoryUsages InventoryUsage[]


  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Batch {
  id          String      @id @default(cuid())
  batchNumber String
  startDate   DateTime
  endDate     DateTime?
  status      BatchStatus @default(ACTIVE)
  initialChicks Int
  notes       String?

  // Removed currentChicks - will be computed from mortalities
  initialChickWeight Decimal @db.Decimal(6, 2) @default(0.045) // Default 45g per chick
  
  // Relationships
  farmId      String
  farm        Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  sales       Sale[]
  mortalities Mortality[]
  vaccinations Vaccination[]
  feedConsumptions FeedConsumption[]
  birdWeights BirdWeight[]
  inventoryUsages InventoryUsage[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([farmId, batchNumber])
  @@index([farmId, startDate])
}

// ==================== UNIFIED CATEGORY MODEL ====================


// category enum

enum CategoryType {
  EXPENSE
  SALES
  INVENTORY
}

// 🔗 NEW: Inventory item types based on supplier
enum InventoryItemType {
  FEED           // From Dealers
  CHICKS         // From Hatcheries  
  MEDICINE       // From Medicine Suppliers
  EQUIPMENT      // General equipment
  OTHER          // Other items
}

model Category {
  id          String   @id @default(cuid())
  name        String
  type        CategoryType
  description String?
  
  // Relationships
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  sales       Sale[]
  inventoryItems InventoryItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, type, name])
  @@index([userId, type])
}

// ==================== EXPENSES & SALES ====================

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  quantity    Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal? @db.Decimal(10, 2)
  
  // Relationships
  farmId      String?
  farm        Farm?     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  inventoryUsages InventoryUsage[]
  
  // 🔗 NEW: Connect to supplier transactions
  entityTransactions EntityTransaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([farmId, date])
  @@index([batchId])
}

model Sale {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Decimal  @db.Decimal(10, 2)
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  description String?
  
  // Credit tracking (simplified)
  isCredit    Boolean  @default(false)
  paidAmount  Decimal  @db.Decimal(10, 2) @default(0)
  dueAmount   Decimal?  @db.Decimal(10, 2) @default(0)
  // Relationships
  farmId      String?
  farm        Farm?     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batchId     String?
  batch       Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payments    SalePayment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([farmId, date])
  @@index([customerId])
}

// Track partial payments for credit sales
model SalePayment {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  description String?
  
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([saleId, date])
}

// ==================== INVENTORY SYSTEM (FIXED) ====================

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  currentStock Decimal @db.Decimal(10, 2) @default(0)
  unit        String
  minStock    Decimal? @db.Decimal(10, 2)
  
  // 🔗 NEW: Item type based on supplier
  itemType    InventoryItemType @default(OTHER)
  
  // Relationships
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions InventoryTransaction[]
  usages      InventoryUsage[]
  
  // 🔗 NEW: Connect to supplier transactions
  entityTransactions EntityTransaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, categoryId, name])
}

model InventoryTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  quantity    Decimal         @db.Decimal(10, 2)
  unitPrice   Decimal         @db.Decimal(10, 2)
  totalAmount Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  
  // Relationships
  itemId      String
  item        InventoryItem   @relation(fields: [itemId], references: [id], onDelete: Restrict)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([itemId, date])
}

// Usage records that automatically update stock
model InventoryUsage {
  id          String   @id @default(cuid())
  date        DateTime
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal? @db.Decimal(10, 2)
  totalAmount Decimal? @db.Decimal(10, 2)
  notes       String?
  
  // Relationships
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  expenseId   String?
  expense     Expense?      @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  batchId     String?
  batch       Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)
  farmId      String
  farm        Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([farmId, date])
  @@index([batchId])
  @@index([itemId])
}

// ==================== UNIFIED TRANSACTION MODEL ====================

model EntityTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  quantity    Int?            // For hatchery chicks, medicine units
  itemName    String?         // For medicine names
  date        DateTime
  description String?
  reference   String?         // Invoice/receipt number
  
  // ✅ Proper foreign key relationships
  dealerId    String?
  dealer      Dealer?         @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  
  hatcheryId  String?
  hatchery    Hatchery?       @relation(fields: [hatcheryId], references: [id], onDelete: Cascade)
  
  medicineSupplierId String?
  medicineSupplier   MedicineSupplier? @relation(fields: [medicineSupplierId], references: [id], onDelete: Cascade)
  
  customerId  String?
  customer    Customer?       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  // 🔗 NEW: Connect to inventory system
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  
  // 🔗 NEW: Connect to expense system
  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  
  // Keep generic fields for backward compatibility and flexibility
  entityType  String?         // "DEALER", "HATCHERY", "MEDICINE_SUPPLIER", "CUSTOMER"
  entityId    String?         // The actual entity ID (for custom entities)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dealerId, date])
  @@index([hatcheryId, date])
  @@index([medicineSupplierId, date])
  @@index([customerId, date])
  @@index([entityType, entityId, date])
  @@index([inventoryItemId, date])
}

// ==================== SUPPLIERS (SIMPLIFIED) ====================

model Dealer {
  id          String   @id @default(cuid())
  name        String
  contact     String
  address     String?
  // Removed balance field - computed from EntityTransaction
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // ✅ Direct relationship to transactions
  transactions EntityTransaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, name])
}

model Hatchery {
  id          String   @id @default(cuid())
  name        String
  contact     String
  address     String?
  // Removed balance field - computed from EntityTransaction
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // ✅ Direct relationship to transactions
  transactions EntityTransaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, name])
}

model MedicineSupplier {
  id          String   @id @default(cuid())
  name        String
  contact     String
  address     String?
  // Removed balance field - computed from EntityTransaction
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // ✅ Direct relationship to transactions
  transactions EntityTransaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, name])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String
  category    String?
  address     String?
  balance     Decimal  @db.Decimal(10, 2) @default(0) // Positive: they owe us
  
  // Relationships
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales       Sale[]
  transactions CustomerTransaction[]
  
  // ✅ Direct relationship to entity transactions
  entityTransactions EntityTransaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, name])
}

model CustomerTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  reference   String?
  
  // Relationships
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId, date])
}

// ==================== BATCH TRACKING ====================

model Mortality {
  id          String   @id @default(cuid())
  date        DateTime
  count       Int
  reason      String?
  
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([batchId, date])
}

model Vaccination {
  id          String            @id @default(cuid())
  vaccineName String
  scheduledDate DateTime
  completedDate DateTime?
  status      VaccinationStatus @default(PENDING) // Fixed: proper enum
  notes       String?
  
  batchId     String
  batch       Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([batchId, scheduledDate])
}

model FeedConsumption {
  id          String   @id @default(cuid())
  date        DateTime
  quantity    Decimal  @db.Decimal(10, 2)
  feedType    String
  
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([batchId, date])
}

model BirdWeight {
  id          String   @id @default(cuid())
  date        DateTime
  avgWeight   Decimal  @db.Decimal(6, 2)  // Average weight per bird in kg
  sampleCount Int      // Number of birds weighed for this average
  
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([batchId, date])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id          String            @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  status      NotificationStatus @default(PENDING)
  data        Json?             // Additional data for the notification
  
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== AUDIT TRAIL ====================

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  tableName   String
  recordId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}

// ==================== COMPUTED ANALYTICS (REMOVED STORED MODELS) ====================
// BatchAnalytics and FarmAnalytics models removed - compute on demand
// LifetimeData model removed - compute on demand

/*
COMPUTED VALUES TO CALCULATE IN APPLICATION:

1. Current Chicks in Batch:
   batch.initialChicks - sum(mortalities.count)

2. Balance for any Entity:
   sum(EntityTransaction where type in [PURCHASE, ADJUSTMENT] and amount > 0) - 
   sum(EntityTransaction where type in [PAYMENT, RECEIPT])

3. Inventory currentStock:
   sum(InventoryTransaction where type = PURCHASE) - 
   sum(InventoryUsage.quantity)

4. FCR (Feed Conversion Ratio):
   Total Feed Consumed / Current Live Weight
   (not weight gain)

5. Outstanding Credit Sales:
   sale.amount - sale.paidAmount (or sum of SalePayments)

6. Farm/Batch Analytics:
   Compute from related expenses, sales, mortalities, etc.
*/