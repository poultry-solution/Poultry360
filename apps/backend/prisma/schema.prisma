// Poultry360 - Fixed Database Schema
// PostgreSQL with Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  OWNER
  MANAGER
  DOCTOR
  DEALER
  COMPANY
  SUPER_ADMIN
}

enum BatchStatus {
  ACTIVE
  COMPLETED
  // CANCELLED
}

enum TransactionType {
  PURCHASE
  SALE
  PAYMENT
  RECEIPT
  ADJUSTMENT
  OPENING_BALANCE
  USAGE
  RETURN
}

enum NotificationType {
  // Chat notifications
  CHAT_MESSAGE

  // Batch management
  BATCH_UPDATE
  MORTALITY_ALERT
  FEED_WARNING
  SALES_NOTIFICATION

  // Farm operations
  FARM_ALERT
  EXPENSE_WARNING
  LOW_INVENTORY

  // System notifications
  SYSTEM

  // Alert notifications (as requested)
  VACCINATION_ALERT
  REMINDER_ALERT
  REQUEST_ALERT

  // Reminder-specific notifications
  VACCINATION_REMINDER
  FEEDING_REMINDER
  MEDICATION_REMINDER
  CLEANING_REMINDER
  WEIGHING_REMINDER
  SUPPLIER_PAYMENT_REMINDER
  CUSTOMER_PAYMENT_REMINDER
  GENERAL_REMINDER

  // Legacy types (keeping for backward compatibility)
  VACCINATION_DUE
  BATCH_COMPLETION
  PAYMENT_DUE
  FEED_REMINDER
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VIDEO
  AUDIO
  PDF
  DOC
  OTHER
  BATCH_SHARE
  FARM_SHARE
}

enum NotificationStatus {
  PENDING
  READ
  DISMISSED
}

enum VaccinationStatus {
  PENDING
  COMPLETED
  MISSED
  OVERDUE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ==================== CORE MODELS ====================

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
}

enum Language {
  ENGLISH
  NEPALI
}

enum CalendarType {
  AD
  BS
}

enum ConsignmentStatus {
  CREATED // S0 - Request/offer formed
  ACCEPTED_PENDING_DISPATCH // S1 - Waiting for dispatch
  DISPATCHED // S2 - Goods shipped
  RECEIVED // S3 - Inventory transferred, sale created
  SETTLED // S4 - Fully paid
  REJECTED // Rejected before dispatch
  CANCELLED // Cancelled before dispatch
}

enum ConsignmentDirection {
  COMPANY_TO_DEALER
  DEALER_TO_COMPANY
  DEALER_TO_FARMER
}

enum DealerSaleRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DealerSalePaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENT
  FLAT
}

enum DiscountScope {
  SALE
  ITEM
}

enum LedgerEntryType {
  SALE
  PURCHASE
  PAYMENT_RECEIVED
  PAYMENT_MADE
  RETURN
  ADJUSTMENT
  OPENING_BALANCE
  ADVANCE_RECEIVED // Prepayment from dealer
  CONSIGNMENT_INVOICE // When S3 creates sale
  CONSIGNMENT_SETTLED // When fully paid
}

enum PaymentRequestStatus {
  PENDING // Company sent request, waiting for dealer acceptance
  ACCEPTED // Dealer accepted the request (acknowledged they need to pay)
  PAYMENT_SUBMITTED // Dealer submitted payment proof (receipt/transaction ID)
  VERIFIED // Company verified and approved the payment
  REJECTED // Company rejected the payment proof
  CANCELLED // Request cancelled by either party
}

enum PaymentRequestDirection {
  COMPANY_TO_DEALER // Company requests payment from dealer
  DEALER_TO_COMPANY // Dealer submits payment for company verification
}

enum DealerVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PurchaseCategory {
  FEED
  MEDICINE
  CHICKS
  EQUIPMENT
  OTHER
}

model User {
  id    String @id @default(cuid())
  phone String @unique
  name  String //name of the user 

  companyName         String? //name of the company
  CompanyFarmLocation String? // Province + Location 

  password String

  role     UserRole   @default(OWNER)
  status   UserStatus @default(PENDING_VERIFICATION)
  isOnline Boolean    @default(false)
  lastSeen DateTime?

  // User preferences
  language     Language     @default(ENGLISH)
  calendarType CalendarType @default(AD)

  // Push notification settings
  pushSubscription     Json? // Web Push subscription object
  notificationEnabled  Boolean @default(true)
  notificationSettings Json? // User preferences for notification types

  // Relationships
  // Farms this user owns
  ownedFarms Farm[]

  // Farms this user manages
  managedFarms Farm[] @relation("FarmManagers")

  customers        Customer[] @relation("CustomerOwner")
  customerRecords  Customer[] @relation("CustomerFarmer") // Reverse relation for connected farmers
  notifications    Notification[]
  reminders        Reminder[]
  vaccinations     Vaccination[]
  auditLogs        AuditLog[]

  // Categories (unified)
  categories Category[]

  // Suppliers (simplified - no balance fields)
  dealers    Dealer[]   @relation("DealerCreator")
  hatcheries Hatchery[]

  medicineSuppliers MedicineSupplier[]

  dealer Dealer? @relation("DealerOwner")

  managedDealers Dealer[] @relation("DealerManagers")

  company Company? @relation("CompanyOwner")

  managedCompanies Company[] @relation("CompanyManagedBy")
  suppliedProducts Product[] @relation("ProductSupplier")

  // Inventory
  inventoryItems InventoryItem[]

  // Egg inventory (Layers: by category)
  eggInventories EggInventory[]

  // Chat relationships
  farmerConversations Conversation[] @relation("FarmerConversations")
  doctorConversations Conversation[] @relation("DoctorConversations")
  sentMessages        Message[]

  // Batch share relationships
  batchSharesOwned    BatchShare[]     @relation("BatchShareOwner")
  batchSharesReceived BatchShare[]     @relation("BatchShareRecipient")
  batchShareViews     BatchShareView[] @relation("BatchShareViewer")

  // Dealer sales relationships
  dealerSalesReceived DealerSale[] @relation("DealerSalesToFarmer")

  // Company sales relationships
  companySalesMade CompanySale[]

  // Consignment relationships
  consignmentsReceived   ConsignmentRequest[]  @relation("FarmerConsignments")
  dispatchedConsignments ConsignmentRequest[]  @relation("DispatchedConsignments")
  receivedConsignments   ConsignmentRequest[]  @relation("ReceivedConsignments")
  consignmentAuditLogs   ConsignmentAuditLog[] @relation("ConsignmentAuditLogs")

  // Payment Request relationships
  paymentRequestsCreated   PaymentRequest[] @relation("PaymentRequestCreatedBy")
  paymentRequestsAccepted  PaymentRequest[] @relation("PaymentRequestAcceptedBy")
  paymentRequestsSubmitted PaymentRequest[] @relation("PaymentRequestSubmittedBy")
  paymentRequestsReviewed  PaymentRequest[] @relation("PaymentRequestReviewedBy")

  // Company-Dealer account payments
  companyDealerPaymentsRecorded CompanyDealerPayment[] @relation("CompanyDealerPaymentRecorder")

  balanceLimitsSet CompanyDealerAccount[] @relation("BalanceLimitSetter")

  // Dealer-Farmer relationships
  dealerConnections           DealerFarmer[]                 @relation("FarmerDealers")
  dealerVerificationRequests  FarmerVerificationRequest[]    @relation("FarmerVerificationRequests")
  saleRequestsReceived        DealerSaleRequest[]            @relation("FarmerSaleRequests")
  salePaymentRequestsAsFarmer DealerSalePaymentRequest[]     @relation("FarmerPaymentRequests")

  // Dealer-Farmer account relationships
  farmerAccounts                  DealerFarmerAccount[]          @relation("FarmerAccounts")
  farmerPaymentsRecorded          DealerFarmerPayment[]          @relation("DealerFarmerPaymentRecorder")
  dealerFarmerBalanceLimitsSet    DealerFarmerAccount[]          @relation("DealerFarmerBalanceLimitSetter")

  // Farmer purchase request relationships
  farmerCarts              FarmerCart[]              @relation("FarmerCarts")
  farmerPurchaseRequests   FarmerPurchaseRequest[]   @relation("FarmerPurchaseRequests")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String @unique
  owner   User   @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  managedBy            User[]                      @relation("CompanyManagedBy")
  dealerCompanies      DealerCompany[]
  consignments         ConsignmentRequest[]        @relation("CompanyConsignments")
  companySales         CompanySale[]
  ledgerEntries        CompanyLedgerEntry[]
  paymentRequests      PaymentRequest[]
  verificationRequests DealerVerificationRequest[]
  dealerCarts          DealerCart[]
  dealerAccounts       CompanyDealerAccount[]

  @@index([ownerId])
}

model Farm {
  id   String @id @default(cuid())
  name String

  capacity    Int
  description String?

  // Relationships
  // Owner (one-to-many)
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Managers (many-to-many)
  managers User[] @relation("FarmManagers")

  batches         Batch[]
  expenses        Expense[]
  sales           Sale[]
  inventoryUsages InventoryUsage[]
  notifications   Notification[]
  reminders       Reminder[]
  vaccinations    Vaccination[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BatchType {
  BROILER
  LAYERS
}

model Batch {
  id            String      @id @default(cuid())
  batchNumber   String
  startDate     DateTime
  endDate       DateTime?
  status        BatchStatus @default(ACTIVE)
  batchType     BatchType   @default(BROILER)
  initialChicks Int
  notes         String?

  // Removed currentChicks - will be computed from mortalities
  // Removed initialChickWeight - replaced with currentWeight

  // Current average weight per bird (denormalized from latest BirdWeight for quick access)
  // This is automatically updated when a new BirdWeight record is added or a sale is recorded
  currentWeight Decimal? @db.Decimal(6, 2) // kg per bird, nullable initially

  // Relationships
  farmId           String
  farm             Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  expenses         Expense[]
  sales            Sale[]
  mortalities      Mortality[]
  vaccinations     Vaccination[]
  feedConsumptions FeedConsumption[]
  birdWeights      BirdWeight[]
  inventoryUsages  InventoryUsage[]
  notifications    Notification[]
  reminders        Reminder[]

  // Shares referencing this batch
  batchShares BatchShare[]

  // Layers: daily egg production (one record per batch per day)
  eggProductions EggProduction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, batchNumber])
  @@index([farmId, startDate])
}

// ==================== EGG MODELS (LAYERS) ====================

enum EggCategory {
  LARGE
  MEDIUM
  SMALL
}

model EggProduction {
  id          String   @id @default(cuid())
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  date        DateTime
  largeCount  Int      @default(0)
  mediumCount Int      @default(0)
  smallCount  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, date])
  @@index([batchId, date])
}

model EggInventory {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  eggCategory EggCategory
  quantity    Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, eggCategory])
  @@index([userId])
}

// ==================== UNIFIED CATEGORY MODEL ====================

// category enum

enum CategoryType {
  EXPENSE
  SALES
  INVENTORY
}

// 🔗 NEW: Inventory item types based on supplier
enum InventoryItemType {
  FEED // From Dealers
  CHICKS // From Hatcheries  
  MEDICINE // From Medicine Suppliers
  EQUIPMENT // General equipment
  OTHER // Other items
}

model Product {
  id           String            @id @default(cuid())
  name         String
  description  String?
  type         InventoryItemType
  unit         String
  unitSellingPrice Decimal           @db.Decimal(10, 2)
  unitCostPrice Decimal           @default(0) @db.Decimal(10, 2)
  quantity     Decimal           @db.Decimal(10, 2)
  currentStock Decimal           @default(0) @db.Decimal(10, 2)
  totalPrice   Decimal           @db.Decimal(10, 2)
  imageUrl     String?           // Product image URL (static URL for now, designed for future file uploads)
  supplierId   String?
  supplier     User?             @relation("ProductSupplier", fields: [supplierId], references: [id], onDelete: Cascade)

  dealerProducts   DealerProduct[]
  consignmentItems ConsignmentItem[]
  companySaleItems CompanySaleItem[]
  cartItems        DealerCartItem[]
  unitConversions  ProductUnitConversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String       @id @default(cuid())
  name        String
  type        CategoryType
  description String?

  // Relationships
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses       Expense[]
  sales          Sale[]
  inventoryItems InventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type, name])
  @@index([userId, type])
}

// ==================== EXPENSES & SALES ====================

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  quantity    Decimal? @db.Decimal(10, 2)
  weight      Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal? @db.Decimal(10, 2)

  // Relationships
  farmId String?
  farm   Farm?   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  batchId         String?
  batch           Batch?           @relation(fields: [batchId], references: [id], onDelete: SetNull)
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  inventoryUsages InventoryUsage[]

  // 🔗 NEW: Connect to supplier transactions
  entityTransactions EntityTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmId, date])
  @@index([batchId])
}

enum SalesItemType {
  EGGS
  Chicken_Meat
  CHICKS
  FEED
  MEDICINE
  EQUIPMENT
  OTHER
}

model Sale {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Decimal  @db.Decimal(10, 2)
  quantity    Decimal  @db.Decimal(10, 2)
  weight      Decimal? @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  description String?

  itemType    SalesItemType @default(Chicken_Meat)
  eggCategory EggCategory?  // For EGGS sales: LARGE, MEDIUM, SMALL
  // Credit tracking (simplified)
  isCredit    Boolean       @default(false)
  paidAmount  Decimal       @default(0) @db.Decimal(10, 2)
  dueAmount   Decimal?      @default(0) @db.Decimal(10, 2)
  // Relationships
  farmId      String?
  farm        Farm?         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batchId     String?
  batch       Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  customerId  String?
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payments    SalePayment[]
  mortality   Mortality?    @relation(fields: [mortalityId], references: [id], onDelete: Cascade)
  mortalityId String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([farmId, date])
  @@index([customerId])
  @@index([mortalityId])
}

// Track partial payments for credit sales
model SalePayment {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @default(now())
  description String?
  receiptUrl  String? // Payment receipt image URL

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([saleId, date])
}

// ==================== INVENTORY SYSTEM (FIXED) ====================

model InventoryItem {
  id           String   @id @default(cuid())
  name         String
  description  String?
  currentStock Decimal  @default(0) @db.Decimal(10, 2)
  unit         String
  minStock     Decimal? @db.Decimal(10, 2)

  // 🔗 NEW: Item type based on supplier
  itemType InventoryItemType @default(OTHER)

  // Relationships
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions InventoryTransaction[]
  usages       InventoryUsage[]

  // 🔗 NEW: Connect to supplier transactions
  entityTransactions EntityTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoryId, name])
}

model InventoryTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  quantity    Decimal         @db.Decimal(10, 2)
  unitPrice   Decimal         @db.Decimal(10, 2)
  totalAmount Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  unit        String?

  // Relationships
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId, date])
}

// Usage records that automatically update stock
model InventoryUsage {
  id          String   @id @default(cuid())
  date        DateTime
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal? @db.Decimal(10, 2)
  totalAmount Decimal? @db.Decimal(10, 2)
  notes       String?

  // Relationships
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  expenseId String?
  expense   Expense?      @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  batchId   String?
  batch     Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)
  farmId    String
  farm      Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmId, date])
  @@index([batchId])
  @@index([itemId])
}

// ==================== UNIFIED TRANSACTION MODEL ====================

model EntityTransaction {
  id           String          @id @default(cuid())
  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  quantity     Int? // Paid quantity (for hatchery chicks, medicine units)
  // Free quantity provided at zero cost (e.g., free chicks from hatchery)
  freeQuantity Int?
  itemName     String? // For medicine names
  date         DateTime
  description  String?
  reference    String? // Invoice/receipt number
  imageUrl     String? // Receipt/Proof image URL

  // ✅ Proper foreign key relationships
  dealerId String?
  dealer   Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  hatcheryId String?
  hatchery   Hatchery? @relation(fields: [hatcheryId], references: [id], onDelete: Cascade)

  medicineSupplierId String?
  medicineSupplier   MedicineSupplier? @relation(fields: [medicineSupplierId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // 🔗 NEW: Connect to inventory system
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  // 🔗 NEW: Connect to expense system
  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  // 🔗 NEW: Payment-to-Purchase relationship
  paymentToPurchaseId String?
  paymentToPurchase   EntityTransaction?  @relation("PaymentToPurchase", fields: [paymentToPurchaseId], references: [id], onDelete: SetNull)
  paymentsForPurchase EntityTransaction[] @relation("PaymentToPurchase")

  // Keep generic fields for backward compatibility and flexibility
  entityType String? // "DEALER", "HATCHERY", "MEDICINE_SUPPLIER", "CUSTOMER"
  entityId   String? // The actual entity ID (for custom entities)

  // Purchase category: what type of item was purchased (for unified supplier tracking)
  // Only set on PURCHASE transactions; null for PAYMENT, ADJUSTMENT, legacy rows
  purchaseCategory PurchaseCategory?

  unit      String?
  unitPrice Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealerId, date])
  @@index([hatcheryId, date])
  @@index([medicineSupplierId, date])
  @@index([customerId, date])
  @@index([entityType, entityId, date])
  @@index([inventoryItemId, date])
  @@index([paymentToPurchaseId, date])
}

// ==================== SUPPLIERS (SIMPLIFIED) ====================

model Dealer {
  id      String  @id @default(cuid())
  name    String
  contact String
  address String?

  // Classification: how this dealer was created
  // "SELF_CREATED" = farmer created locally, "CONNECTED" = connected via verification
  classification String @default("SELF_CREATED")

  // Running balance for self-created (manual) dealers
  // Positive = farmer owes dealer, Negative = advance/overpayment
  balance       Decimal @default(0) @db.Decimal(10, 2)
  totalPurchases Decimal @default(0) @db.Decimal(10, 2)
  totalPayments  Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Farmer who created this dealer (for local/offline dealers)
  userId String?
  user   User?   @relation("DealerCreator", fields: [userId], references: [id], onDelete: Cascade)

  // Owner (dealer authentication / access control)
  ownerId String? @unique
  owner   User?   @relation("DealerOwner", fields: [ownerId], references: [id])

  // NEW: Managers of this dealer (many-to-many)
  managers User[] @relation("DealerManagers")

  // Many-to-many relationship with companies
  companies DealerCompany[]

  // Many-to-many relationship with farmers
  farmerConnections DealerFarmer[]
  farmerRequests    FarmerVerificationRequest[] @relation("DealerFarmerRequests")

  transactions         EntityTransaction[]
  products             DealerProduct[]
  sales                DealerSale[]
  saleRequests         DealerSaleRequest[]
  salePaymentRequests  DealerSalePaymentRequest[]
  consignmentsFrom     ConsignmentRequest[]        @relation("DealerConsignmentsFrom")
  consignmentsTo       ConsignmentRequest[]        @relation("DealerConsignmentsTo")
  ledgerEntries        DealerLedgerEntry[]
  companySales         CompanySale[]
  paymentRequests      PaymentRequest[]
  verificationRequests DealerVerificationRequest[]
  carts                DealerCart[]
  companyAccounts      CompanyDealerAccount[]
  farmerAccounts       DealerFarmerAccount[]
  manualCompanies      DealerManualCompany[]
  farmerCarts          FarmerCart[]              @relation("DealerFarmerCarts")
  farmerPurchaseRequests FarmerPurchaseRequest[] @relation("DealerPurchaseRequests")

  @@unique([userId, name])
  @@index([ownerId])
}

// ==================== DEALER CART MODELS ====================

model DealerCart {
  id        String   @id @default(cuid())
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items     DealerCartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, companyId]) // One cart per dealer-company pair
  @@index([dealerId])
  @@index([companyId])
}

model DealerCartItem {
  id        String     @id @default(cuid())
  cartId    String
  cart      DealerCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal    @db.Decimal(10, 2)
  unitPrice Decimal    @db.Decimal(10, 2) // Frozen price at time of adding to cart

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId]) // One entry per product per cart
  @@index([cartId])
  @@index([productId])
}

model Hatchery {
  id      String  @id @default(cuid())
  name    String
  contact String
  address String?
  // Removed balance field - computed from EntityTransaction

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ✅ Direct relationship to transactions
  transactions EntityTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model MedicineSupplier {
  id      String  @id @default(cuid())
  name    String
  contact String
  address String?
  // Removed balance field - computed from EntityTransaction

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ✅ Direct relationship to transactions
  transactions EntityTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model Customer {
  id       String  @id @default(cuid())
  name     String
  phone    String
  category String?
  address  String?
  balance  Decimal @default(0) @db.Decimal(10, 2) // Positive: they owe us

  // Customer source tracking
  source   String  @default("MANUAL") // "MANUAL" | "CONNECTED"
  farmerId String? // Link to connected farmer (null for manual customers)

  // Relationships
  userId           String
  user             User                  @relation("CustomerOwner", fields: [userId], references: [id], onDelete: Cascade)
  connectedFarmer  User?                 @relation("CustomerFarmer", fields: [farmerId], references: [id], onDelete: SetNull)
  sales            Sale[]
  transactions     CustomerTransaction[]

  // ✅ Direct relationship to entity transactions
  entityTransactions EntityTransaction[]

  // Dealer sales relationships
  dealerSales         DealerSale[]
  saleRequests        DealerSaleRequest[]
  salePaymentRequests DealerSalePaymentRequest[]
  farmerPurchaseRequests FarmerPurchaseRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@unique([userId, farmerId]) // Prevent duplicate customers for same farmer-dealer pair
}

model CustomerTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  reference   String?
  imageUrl    String? // Payment/Transaction related image URL

  // Relationships
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, date])
}

// ==================== BATCH TRACKING ====================

model Mortality {
  id     String   @id @default(cuid())
  date   DateTime
  count  Int
  reason String?

  saleId String?
  sale   Sale?   @relation

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId, date])
  @@index([saleId, date])
}

model Vaccination {
  id            String            @id @default(cuid())
  vaccineName   String
  scheduledDate DateTime
  completedDate DateTime?
  status        VaccinationStatus @default(PENDING) // Fixed: proper enum
  notes         String?

  // NEW: Reminder integration
  reminderCreated Boolean   @default(false) // Track if reminder was created
  reminderId      String?   @unique // Link to reminder
  reminder        Reminder?

  // NEW: Multi-dose support
  doseNumber       Int  @default(1) // 1st dose, 2nd dose, etc.
  totalDoses       Int  @default(1) // Total doses required
  daysBetweenDoses Int? // Days between doses

  // NEW: Standard vaccination schedule integration
  standardScheduleId String? // Link to standard schedule
  standardSchedule   StandardVaccinationSchedule? @relation(fields: [standardScheduleId], references: [id])
  batchAge           Int? // Age of batch when vaccination was due
  retryCount         Int                          @default(0) // Number of retry attempts

  // NEW: Flexible context relationships (can be tied to batch, farm, or neither)
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  farmId  String?
  farm    Farm?   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  // NEW: User ownership for farm-level or general vaccinations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId, scheduledDate])
  @@index([farmId, scheduledDate])
  @@index([userId, scheduledDate])
  @@index([status, scheduledDate])
  @@index([standardScheduleId])
  @@index([batchId, batchAge])
}

// Standard vaccination schedule for systematic batch-age-based vaccinations
model StandardVaccinationSchedule {
  id          String  @id @default(cuid())
  vaccineName String // e.g., "IB (Infectious Bronchitis)"
  dayFrom     Int // Start day (e.g., 1)
  dayTo       Int // End day (e.g., 1) 
  isOptional  Boolean @default(false) // e.g., IBH/HPS is optional
  description String? // Additional details
  isActive    Boolean @default(true) // Can be disabled by admin

  // Related vaccinations
  vaccinations Vaccination[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayFrom, dayTo])
  @@index([isActive])
}

model FeedConsumption {
  id       String   @id @default(cuid())
  date     DateTime
  quantity Decimal  @db.Decimal(10, 2)
  feedType String

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId, date])
}

model BirdWeight {
  id          String       @id @default(cuid())
  date        DateTime
  avgWeight   Decimal      @db.Decimal(6, 2) // Average weight per bird in kg
  sampleCount Int // Number of birds weighed for this average
  source      WeightSource @default(MANUAL) // How this weight was recorded
  notes       String? // Optional notes about the weighing

  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId, date])
}

enum WeightSource {
  MANUAL // Farmer manually entered
  SALE // Computed from sales data
  SYSTEM // System calculated
}

// ==================== REMINDERS ====================

enum ReminderType {
  VACCINATION
  FEEDING
  MEDICATION
  CLEANING
  WEIGHING
  SUPPLIER_PAYMENT
  CUSTOMER_PAYMENT
  GENERAL
}

enum ReminderStatus {
  PENDING
  COMPLETED
  CANCELLED
  OVERDUE
}

enum RecurrencePattern {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model Reminder {
  id          String         @id @default(cuid())
  title       String
  description String?
  type        ReminderType
  status      ReminderStatus @default(PENDING)

  // Scheduling
  dueDate            DateTime
  isRecurring        Boolean           @default(false)
  recurrencePattern  RecurrencePattern @default(NONE)
  recurrenceInterval Int? // Every X days/weeks/months
  lastTriggered      DateTime? // Last time this reminder was triggered

  // Optional context relationships
  farmId  String?
  farm    Farm?   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  // NEW: Vaccination integration
  vaccinationId String?      @unique
  vaccination   Vaccination? @relation(fields: [vaccinationId], references: [id])

  // Additional data for specific reminder types
  data Json? // Store specific data like supplier ID, customer ID, etc.

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([farmId, dueDate])
  @@index([batchId, dueDate])
  @@index([type, dueDate])
  @@index([vaccinationId])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id    String           @id @default(cuid())
  type  NotificationType
  title String
  body  String // Changed from 'message' to 'body' for consistency
  data  Json? // Additional data for the notification
  read  Boolean          @default(false) // For push notifications

  // Optional context relationships
  farmId  String?
  farm    Farm?   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== DEALER-COMPANY RELATIONSHIP (MANY-TO-MANY) ====================

model DealerCompany {
  id        String  @id @default(cuid())
  dealerId  String
  dealer    Dealer  @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Metadata
  connectedAt  DateTime @default(now()) // When relationship was established
  connectedVia String? // "VERIFICATION" | "MANUAL" | "MIGRATION"
  
  // Archive flags (independent per party)
  archivedByDealer  Boolean @default(false) // Dealer archived this connection
  archivedByCompany Boolean @default(false) // Company archived this connection

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, companyId]) // One relationship per dealer-company pair
  @@index([dealerId])
  @@index([companyId])
  @@index([companyId, dealerId])
  @@index([dealerId, archivedByDealer]) // For filtering dealer's archived/active
  @@index([companyId, archivedByCompany]) // For filtering company's archived/active
}

// ==================== DEALER-FARMER RELATIONSHIP ====================

model DealerFarmer {
  id       String @id @default(cuid())
  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  farmerId String
  farmer   User   @relation("FarmerDealers", fields: [farmerId], references: [id], onDelete: Cascade)

  // Metadata
  connectedAt  DateTime @default(now()) // When relationship was established
  connectedVia String? // "VERIFICATION" | "MANUAL" | "MIGRATION"
  
  // Archive flags (independent per party)
  archivedByDealer Boolean @default(false) // Dealer archived this connection
  archivedByFarmer Boolean @default(false) // Farmer archived this connection

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, farmerId]) // One relationship per dealer-farmer pair
  @@index([dealerId])
  @@index([farmerId])
  @@index([farmerId, dealerId])
  @@index([dealerId, archivedByDealer]) // For filtering dealer's archived/active
  @@index([farmerId, archivedByFarmer]) // For filtering farmer's archived/active
}

// ==================== DEALER-FARMER ACCOUNT SYSTEM ====================

model DealerFarmerAccount {
  id        String   @id @default(cuid())
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  farmerId  String
  farmer    User     @relation("FarmerAccounts", fields: [farmerId], references: [id], onDelete: Cascade)

  // Running balance (positive = farmer owes dealer, negative = advance/credit)
  balance         Decimal @default(0) @db.Decimal(10, 2)

  // Totals for reference
  totalSales      Decimal @default(0) @db.Decimal(10, 2)
  totalPayments   Decimal @default(0) @db.Decimal(10, 2)

  // Timestamps
  lastSaleDate    DateTime?
  lastPaymentDate DateTime?

  // Balance limit feature (optional - for future use)
  balanceLimit    Decimal?  @db.Decimal(10, 2)
  balanceLimitSetAt DateTime?
  balanceLimitSetBy String?
  balanceLimitSetByUser User? @relation("DealerFarmerBalanceLimitSetter", fields: [balanceLimitSetBy], references: [id])

  sales    DealerSale[]
  payments DealerFarmerPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, farmerId])
  @@index([dealerId])
  @@index([farmerId])
}

model DealerFarmerPayment {
  id          String   @id @default(cuid())
  accountId   String
  account     DealerFarmerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  amount          Decimal  @db.Decimal(10, 2)
  paymentMethod   String   @default("CASH")
  paymentDate     DateTime @default(now())
  notes           String?
  reference       String?

  // Optional proof/receipt images
  receiptImageUrl String?
  proofImageUrl   String?

  // Balance snapshot after this payment
  balanceAfter    Decimal  @db.Decimal(10, 2)

  // User who recorded the payment (dealer or farmer)
  recordedById String
  recordedBy   User   @relation("DealerFarmerPaymentRecorder", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())

  @@index([accountId, paymentDate])
}

// ==================== DEALER VERIFICATION REQUESTS ====================

model DealerVerificationRequest {
  id        String  @id @default(cuid())
  dealerId  String
  dealer    Dealer  @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  status         DealerVerificationStatus @default(PENDING)
  rejectedCount  Int                      @default(0) // Track rejection count per company
  lastRejectedAt DateTime? // For 1-hour cooldown
  acknowledgedAt DateTime? // Track if dealer saw message

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, companyId, status]) // One pending request per dealer-company
  @@index([dealerId])
  @@index([companyId])
  @@index([companyId, status]) // For company filtering pending requests
}

// ==================== FARMER VERIFICATION REQUESTS ====================

model FarmerVerificationRequest {
  id       String @id @default(cuid())
  farmerId String
  farmer   User   @relation("FarmerVerificationRequests", fields: [farmerId], references: [id], onDelete: Cascade)
  dealerId String
  dealer   Dealer @relation("DealerFarmerRequests", fields: [dealerId], references: [id], onDelete: Cascade)

  status         DealerVerificationStatus @default(PENDING)
  rejectedCount  Int                      @default(0) // Track rejection count per dealer
  lastRejectedAt DateTime? // For 1-hour cooldown
  acknowledgedAt DateTime? // Track if farmer saw message

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmerId, dealerId, status]) // One pending request per farmer-dealer
  @@index([farmerId])
  @@index([dealerId])
  @@index([dealerId, status]) // For dealer filtering pending requests
}

// ==================== AUDIT TRAIL ====================

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ==================== COMPUTED ANALYTICS (REMOVED STORED MODELS) ====================
// BatchAnalytics and FarmAnalytics models removed - compute on demand
// LifetimeData model removed - compute on demand

/**
 * COMPUTED VALUES TO CALCULATE IN APPLICATION:
 * 1. Current Chicks in Batch:
 * batch.initialChicks - sum(mortalities.count)
 * 2. Balance for any Entity:
 * sum(EntityTransaction where type in [PURCHASE, ADJUSTMENT] and amount > 0) -
 * sum(EntityTransaction where type in [PAYMENT, RECEIPT])
 * 3. Inventory currentStock:
 * sum(InventoryTransaction where type = PURCHASE) -
 * sum(InventoryUsage.quantity)
 * 4. FCR (Feed Conversion Ratio):
 * Total Feed Consumed / Current Live Weight
 * (not weight gain)
 * 5. Outstanding Credit Sales:
 * sale.amount - sale.paidAmount (or sum of SalePayments)
 * 6. Farm/Batch Analytics:
 * Compute from related expenses, sales, mortalities, etc.
 */

// ==================== CHAT MODELS ====================

model Conversation {
  id        String             @id @default(cuid())
  farmerId  String
  doctorId  String
  status    ConversationStatus @default(ACTIVE)
  subject   String? // Optional subject/topic
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  messages Message[]
  farmer   User      @relation("FarmerConversations", fields: [farmerId], references: [id])
  doctor   User      @relation("DoctorConversations", fields: [doctorId], references: [id])

  // Shares linked to this conversation
  batchShares BatchShare[]

  @@unique([farmerId, doctorId]) // Prevent duplicate conversations
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  // Optional textual content (e.g., message body or caption for attachments)
  text           String?
  messageType    MessageType @default(TEXT)
  createdAt      DateTime    @default(now())
  read           Boolean     @default(false)
  edited         Boolean     @default(false)
  // Soft delete flag
  isDeleted      Boolean     @default(false)

  // Attachment metadata (for IMAGE/VIDEO/AUDIO/PDF/DOC/FILE/OTHER)
  attachmentUrl String?
  attachmentKey String? // Storage key/path in R2 (or other store)
  fileName      String?
  contentType   String?
  fileSize      Int?
  durationMs    Int? // for audio/video
  width         Int? // for images/videos
  height        Int?
  thumbnailUrl  String?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  // Optional reference to a shared batch snapshot
  batchShareId String?
  batchShare   BatchShare? @relation("MessageToBatchShare", fields: [batchShareId], references: [id])

  @@index([conversationId, createdAt]) // Optimize message queries
}

// ==================== BATCH/FARM SHARING ====================

model BatchShare {
  id         String @id @default(cuid())
  shareToken String @unique @default(cuid())

  // Ownership and context
  batchId        String
  farmerId       String
  sharedWithId   String?
  conversationId String?

  // Snapshot payload (immutable JSON)
  snapshotData Json

  // Metadata
  title       String?
  description String?
  isPublic    Boolean   @default(false)
  expiresAt   DateTime?
  viewCount   Int       @default(0)

  // Relations
  batch        Batch            @relation(fields: [batchId], references: [id])
  farmer       User             @relation("BatchShareOwner", fields: [farmerId], references: [id])
  sharedWith   User?            @relation("BatchShareRecipient", fields: [sharedWithId], references: [id])
  conversation Conversation?    @relation(fields: [conversationId], references: [id])
  views        BatchShareView[]
  // Reverse relation to messages if embedded in chat
  messages     Message[]        @relation("MessageToBatchShare")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shareToken])
  @@index([batchId])
  @@index([conversationId])
}

model BatchShareView {
  id        String   @id @default(cuid())
  shareId   String
  viewerId  String?
  ipAddress String?
  userAgent String?
  viewedAt  DateTime @default(now())

  share  BatchShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  viewer User?      @relation("BatchShareViewer", fields: [viewerId], references: [id])

  @@index([shareId])
}

// ==================== DEALER MODULE MODELS ====================

model DealerProduct {
  id           String            @id @default(cuid())
  name         String
  description  String?
  type         InventoryItemType
  unit         String
  costPrice    Decimal           @db.Decimal(10, 2)
  sellingPrice Decimal           @db.Decimal(10, 2)
  currentStock Decimal           @default(0) @db.Decimal(10, 2)
  minStock     Decimal?          @db.Decimal(10, 2)
  sku          String?

  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  companyProductId String?
  companyProduct   Product? @relation(fields: [companyProductId], references: [id], onDelete: SetNull)

  transactions         DealerProductTransaction[]
  saleItems            DealerSaleItem[]
  consignmentItems     ConsignmentItem[]
  saleRequestItems     DealerSaleRequestItem[]
  manualPurchaseItems  DealerManualPurchaseItem[]
  farmerCartItems             FarmerCartItem[]              @relation("FarmerCartProducts")
  farmerPurchaseRequestItems  FarmerPurchaseRequestItem[]   @relation("FarmerPurchaseRequestProducts")
  unitConversions             DealerProductUnitConversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, name, costPrice, sellingPrice])
  @@index([dealerId])
  @@index([companyProductId])
}

model DealerProductTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  quantity    Decimal         @db.Decimal(10, 2)
  unitPrice   Decimal         @db.Decimal(10, 2)
  totalAmount Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  reference   String?
  unit        String?

  productId String
  product   DealerProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  dealerSaleId String?
  dealerSale   DealerSale? @relation(fields: [dealerSaleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, date])
  @@index([dealerSaleId])
}

model DealerSale {
  id              String    @id @default(cuid())
  invoiceNumber   String?   @unique
  date            DateTime
  subtotalAmount  Decimal?  @db.Decimal(10, 2) // Before discount; null when no discount
  totalAmount     Decimal   @db.Decimal(10, 2)
  paidAmount      Decimal   @default(0) @db.Decimal(10, 2)
  dueAmount       Decimal?  @db.Decimal(10, 2)
  isCredit        Boolean   @default(false)
  notes           String?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  farmerId String?
  farmer   User?   @relation("DealerSalesToFarmer", fields: [farmerId], references: [id], onDelete: SetNull)

  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  // Account-based system - link to dealer-farmer account
  accountId String?
  account   DealerFarmerAccount? @relation(fields: [accountId], references: [id])

  discount        SaleDiscount?
  items           DealerSaleItem[]
  transactions    DealerProductTransaction[]
  payments        DealerSalePayment[]
  paymentRequests DealerSalePaymentRequest[]
  ledgerEntries   DealerLedgerEntry[]
  saleRequest     DealerSaleRequest?
  purchaseRequest FarmerPurchaseRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealerId, date])
  @@index([customerId])
  @@index([farmerId])
  @@index([invoiceNumber])
  @@index([accountId])
}

model DealerSaleItem {
  id           String   @id @default(cuid())
  quantity     Decimal  @db.Decimal(10, 2)
  unitPrice    Decimal  @db.Decimal(10, 2)
  totalAmount  Decimal  @db.Decimal(10, 2)
  unit         String?
  baseQuantity Decimal? @db.Decimal(10, 2)

  saleId String
  sale   DealerSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   DealerProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
}

model DealerSalePayment {
  id            String   @id @default(cuid())
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime @default(now())
  description   String?
  paymentMethod String?

  saleId String
  sale   DealerSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([saleId, date])
}

// ==================== DEALER SALE PAYMENT REQUEST MODELS ====================

model DealerSalePaymentRequest {
  id            String                          @id @default(cuid())
  requestNumber String                          @unique
  status        DealerSalePaymentRequestStatus @default(PENDING)
  amount        Decimal                         @db.Decimal(10, 2)
  description   String?

  // Payment proof details (for future S3 integration)
  paymentMethod     String?
  paymentReference  String? // Bill ID / Transaction ID
  proofOfPaymentUrl String? // Future: S3 file key or URL
  paymentDate       DateTime?

  // Linked sale (optional for ledger-level payments)
  dealerSaleId String?
  dealerSale   DealerSale? @relation(fields: [dealerSaleId], references: [id], onDelete: Cascade)

  // Payment type flag
  isLedgerLevel Boolean @default(false) // true = general payment, false = bill-wise

  // Relationships
  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  farmerId String
  farmer   User @relation("FarmerPaymentRequests", fields: [farmerId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Approval tracking
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealerSaleId, status])
  @@index([dealerId, status])
  @@index([farmerId, status])
}

// ==================== DEALER SALE REQUEST MODELS ====================

model DealerSaleRequest {
  id            String                   @id @default(cuid())
  requestNumber String                   @unique
  status        DealerSaleRequestStatus @default(PENDING)
  
  // Amounts
  totalAmount    Decimal  @db.Decimal(10, 2)
  subtotalAmount Decimal? @db.Decimal(10, 2) // Original before discount; null when no discount
  discountType   String?  // "PERCENT" | "FLAT" when dealer applied discount
  discountValue  Decimal? @db.Decimal(10, 2)
  paidAmount     Decimal  @default(0) @db.Decimal(10, 2)
  
  // Payment details
  paymentMethod String?
  notes         String?
  date          DateTime @default(now())
  
  // Approval/Rejection
  reviewedAt      DateTime?
  rejectionReason String?
  
  // Relationships
  dealerId      String
  dealer        Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  
  farmerId      String   // Connected farmer who must approve
  farmer        User @relation("FarmerSaleRequests", fields: [farmerId], references: [id], onDelete: Cascade)
  
  customerId    String   // The customer record (connected farmer as customer)
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  // Linked records (created on approval)
  dealerSaleId  String?  @unique
  dealerSale    DealerSale? @relation(fields: [dealerSaleId], references: [id])
  
  items         DealerSaleRequestItem[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([dealerId, status])
  @@index([farmerId, status])
  @@index([customerId])
}

model DealerSaleRequestItem {
  id           String   @id @default(cuid())
  quantity     Decimal  @db.Decimal(10, 2)
  unitPrice    Decimal  @db.Decimal(10, 2)
  totalAmount  Decimal  @db.Decimal(10, 2)
  unit         String?
  baseQuantity Decimal? @db.Decimal(10, 2)

  requestId   String
  request     DealerSaleRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  productId   String
  product     DealerProduct @relation(fields: [productId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requestId])
  @@index([productId])
}

model ConsignmentRequest {
  id            String               @id @default(cuid())
  requestNumber String               @unique
  direction     ConsignmentDirection
  status        ConsignmentStatus    @default(CREATED)
  totalAmount   Decimal              @db.Decimal(10, 2)
  subtotalAmount Decimal?            @db.Decimal(10, 2) // Before discount; null when no discount
  discountType   String?             // "PERCENT" | "FLAT" when discount applied
  discountValue  Decimal?            @db.Decimal(10, 2)
  notes         String?

  // Quantity tracking (prepare for partial receipt)
  requestedQuantity  Decimal? @db.Decimal(10, 2)
  approvedQuantity   Decimal? @db.Decimal(10, 2)
  dispatchedQuantity Decimal? @db.Decimal(10, 2)
  receivedQuantity   Decimal? @db.Decimal(10, 2)

  // Dispatch & Receipt documentation
  dispatchRef    String?
  trackingInfo   String?
  grnRef         String? // Goods Received Note
  dispatchedAt   DateTime?
  receivedAt     DateTime?
  dispatchedById String?
  dispatchedBy   User?     @relation("DispatchedConsignments", fields: [dispatchedById], references: [id])
  receivedById   String?
  receivedBy     User?     @relation("ReceivedConsignments", fields: [receivedById], references: [id])

  // Link to created sale (S3)
  companySaleId String?      @unique
  companySale   CompanySale? @relation(fields: [companySaleId], references: [id])

  // Balance limit override (company allowed consignment despite limit)
  overrideBalanceLimit Boolean? @default(false)

  fromCompanyId String?
  fromCompany   Company? @relation("CompanyConsignments", fields: [fromCompanyId], references: [id], onDelete: Cascade)

  fromDealerId String?
  fromDealer   Dealer? @relation("DealerConsignmentsFrom", fields: [fromDealerId], references: [id], onDelete: Cascade)

  toDealerId String?
  toDealer   Dealer? @relation("DealerConsignmentsTo", fields: [toDealerId], references: [id], onDelete: Cascade)

  toFarmerId String?
  toFarmer   User?   @relation("FarmerConsignments", fields: [toFarmerId], references: [id], onDelete: Cascade)

  items         ConsignmentItem[]
  ledgerEntries DealerLedgerEntry[]
  auditLogs     ConsignmentAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fromCompanyId, status])
  @@index([fromDealerId, status])
  @@index([toDealerId, status])
  @@index([toFarmerId, status])
  @@index([requestNumber])
  @@index([dispatchedById])
  @@index([receivedById])
  @@index([companySaleId])
}

model ConsignmentItem {
  id               String   @id @default(cuid())
  quantity         Decimal  @db.Decimal(10, 2)
  acceptedQuantity Decimal? @db.Decimal(10, 2)
  receivedQuantity Decimal? @db.Decimal(10, 2)
  unitPrice        Decimal  @db.Decimal(10, 2)
  totalAmount      Decimal  @db.Decimal(10, 2)
  isAccepted       Boolean  @default(false)
  rejectionReason  String?
  unit             String?
  baseQuantity     Decimal? @db.Decimal(10, 2)

  consignmentId String
  consignment   ConsignmentRequest @relation(fields: [consignmentId], references: [id], onDelete: Cascade)

  companyProductId String?
  companyProduct   Product? @relation(fields: [companyProductId], references: [id], onDelete: SetNull)

  dealerProductId String?
  dealerProduct   DealerProduct? @relation(fields: [dealerProductId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consignmentId])
}

model ConsignmentAuditLog {
  id            String             @id @default(cuid())
  consignmentId String
  consignment   ConsignmentRequest @relation(fields: [consignmentId], references: [id], onDelete: Cascade)

  action     String // CREATED, ACCEPTED, DISPATCHED, RECEIVED, etc.
  statusFrom ConsignmentStatus?
  statusTo   ConsignmentStatus

  actorId String
  actor   User   @relation("ConsignmentAuditLogs", fields: [actorId], references: [id])

  quantityChange Decimal? @db.Decimal(10, 2)
  documentRef    String? // dispatch_ref, grn_ref, etc.
  notes          String?

  createdAt DateTime @default(now())

  @@index([consignmentId])
  @@index([actorId])
}

model DealerLedgerEntry {
  id          String          @id @default(cuid())
  type        LedgerEntryType
  amount      Decimal         @db.Decimal(10, 2)
  balance     Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  reference   String?
  imageUrl    String? // Receipt/Proof image URL

  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  saleId String?
  sale   DealerSale? @relation(fields: [saleId], references: [id], onDelete: SetNull)

  consignmentId String?
  consignment   ConsignmentRequest? @relation(fields: [consignmentId], references: [id], onDelete: SetNull)

  partyId   String?
  partyType String?

  createdAt DateTime @default(now())

  @@index([dealerId, date])
  @@index([partyId, partyType])
  @@index([saleId])
  @@index([consignmentId])
}

// ==================== COMPANY SALES ====================
model CompanySale {
  id              String   @id @default(cuid())
  invoiceNumber   String?  @unique
  date            DateTime @default(now())
  subtotalAmount  Decimal? @db.Decimal(10, 2) // Before discount; null when no discount
  totalAmount     Decimal  @db.Decimal(10, 2)
  isCredit        Boolean  @default(false)
  paymentMethod   String   @default("CASH")
  notes           String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  soldById String
  soldBy   User   @relation(fields: [soldById], references: [id], onDelete: Cascade)

  // Link to consignment (if created from consignment receipt)
  consignmentId String?             @unique
  consignment   ConsignmentRequest?

  // Account-based system - link to dealer account
  accountId String?
  account   CompanyDealerAccount? @relation(fields: [accountId], references: [id])

  // Optional invoice image (for future use)
  invoiceImageUrl String?

  discount        SaleDiscount?
  items           CompanySaleItem[]
  ledgerEntries   CompanyLedgerEntry[]
  paymentRequests PaymentRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, date])
  @@index([dealerId, date])
  @@index([soldById])
  @@index([invoiceNumber])
  @@index([consignmentId])
  @@index([accountId])
}

model CompanySaleItem {
  id           String   @id @default(cuid())
  quantity     Decimal  @db.Decimal(10, 2)
  unitPrice    Decimal  @db.Decimal(10, 2)
  totalAmount  Decimal  @db.Decimal(10, 2)
  unit         String?
  baseQuantity Decimal? @db.Decimal(10, 2)

  saleId String
  sale   CompanySale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
}

// Global or item-level discount on a sale (one per sale for scope SALE; future: scope ITEM per item)
model SaleDiscount {
  id            String        @id @default(cuid())
  type          DiscountType
  value         Decimal       @db.Decimal(10, 2)
  scope         DiscountScope @default(SALE)

  dealerSaleId  String?       @unique
  dealerSale    DealerSale?   @relation(fields: [dealerSaleId], references: [id], onDelete: Cascade)

  companySaleId String?       @unique
  companySale   CompanySale?  @relation(fields: [companySaleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([dealerSaleId])
  @@index([companySaleId])
}

// CompanySalePayment model removed - now using CompanyDealerPayment for account-level payments

// ==================== COMPANY-DEALER ACCOUNT SYSTEM ====================

model CompanyDealerAccount {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  
  // Running balance (positive = dealer owes company, negative = advance/credit)
  balance         Decimal @default(0) @db.Decimal(10, 2)
  
  // Totals for reference
  totalSales      Decimal @default(0) @db.Decimal(10, 2)
  totalPayments   Decimal @default(0) @db.Decimal(10, 2)
  
  // Timestamps
  lastSaleDate    DateTime?
  lastPaymentDate DateTime?
  
  // Balance limit feature
  balanceLimit    Decimal?  @db.Decimal(10, 2) // Maximum allowed balance (null = no limit)
  balanceLimitSetAt DateTime? // When the limit was last set/updated
  balanceLimitSetBy String?   // User ID who set the limit
  balanceLimitSetByUser User? @relation("BalanceLimitSetter", fields: [balanceLimitSetBy], references: [id])
  
  sales    CompanySale[]
  payments CompanyDealerPayment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([companyId, dealerId])
  @@index([companyId])
  @@index([dealerId])
}

model CompanyDealerPayment {
  id          String   @id @default(cuid())
  accountId   String
  account     CompanyDealerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  amount          Decimal  @db.Decimal(10, 2)
  paymentMethod   String   @default("CASH")
  paymentDate     DateTime @default(now())
  notes           String?
  reference       String?
  
  // Optional proof/receipt images (for future use)
  receiptImageUrl String? // Payment receipt uploaded by payer
  proofImageUrl   String? // Additional payment proof
  
  // Balance snapshot after this payment
  balanceAfter    Decimal  @db.Decimal(10, 2)
  
  // User who recorded the payment
  recordedById String
  recordedBy   User   @relation("CompanyDealerPaymentRecorder", fields: [recordedById], references: [id])
  
  createdAt DateTime @default(now())
  
  @@index([accountId, paymentDate])
}

model CompanyLedgerEntry {
  id             String          @id @default(cuid())
  type           LedgerEntryType
  amount         Decimal         @db.Decimal(10, 2)
  runningBalance Decimal         @db.Decimal(10, 2)
  date           DateTime
  description    String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  companySaleId String?
  companySale   CompanySale? @relation(fields: [companySaleId], references: [id], onDelete: SetNull)

  partyId         String?
  partyType       String?
  transactionId   String?
  transactionType TransactionType?
  entryType       LedgerEntryType

  createdAt DateTime @default(now())

  @@index([companyId, date])
  @@index([partyId, partyType])
  @@index([companySaleId])
  @@index([transactionId])
}

// ==================== PAYMENT REQUEST MODEL ====================

model PaymentRequest {
  id            String                  @id @default(cuid())
  requestNumber String                  @unique
  direction     PaymentRequestDirection
  status        PaymentRequestStatus    @default(PENDING)
  amount        Decimal                 @db.Decimal(10, 2)
  description   String?

  // Payment proof details (for dealer-initiated or company-initiated after dealer accepts)
  paymentMethod     String?
  paymentReference  String?
  paymentReceiptUrl String?
  paymentDate       DateTime?

  // Company initiating or receiving the request
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Dealer initiating or receiving the request
  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  // Optional link to a specific CompanySale if the request is for an outstanding balance
  companySaleId String?
  companySale   CompanySale? @relation(fields: [companySaleId], references: [id], onDelete: SetNull)

  // User who created the request
  requestedById String
  requestedBy   User   @relation("PaymentRequestCreatedBy", fields: [requestedById], references: [id])

  // User who accepted the request (dealer side)
  acceptedById String?
  acceptedBy   User?     @relation("PaymentRequestAcceptedBy", fields: [acceptedById], references: [id])
  acceptedAt   DateTime?

  // User who submitted payment proof (dealer side)
  submittedById String?
  submittedBy   User?     @relation("PaymentRequestSubmittedBy", fields: [submittedById], references: [id])
  submittedAt   DateTime?

  // User who reviewed/verified the payment (company side)
  reviewedById String?
  reviewedBy   User?     @relation("PaymentRequestReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([dealerId, status])
  @@index([companySaleId])
  @@index([requestedById])
  @@index([acceptedById])
  @@index([submittedById])
  @@index([reviewedById])
}

// ==================== DEALER MANUAL COMPANY MODELS ====================

model DealerManualCompany {
  id       String  @id @default(cuid())
  name     String
  phone    String?
  address  String?

  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  // Running balance (positive = dealer owes company)
  balance        Decimal @default(0) @db.Decimal(10, 2)
  totalPurchases Decimal @default(0) @db.Decimal(10, 2)
  totalPayments  Decimal @default(0) @db.Decimal(10, 2)

  purchases DealerManualPurchase[]
  payments  DealerManualCompanyPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealerId, name])
  @@index([dealerId])
}

model DealerManualPurchase {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  totalAmount Decimal  @db.Decimal(10, 2)
  notes       String?
  reference   String?

  manualCompanyId String
  manualCompany   DealerManualCompany @relation(fields: [manualCompanyId], references: [id], onDelete: Cascade)

  items DealerManualPurchaseItem[]

  createdAt DateTime @default(now())

  @@index([manualCompanyId, date])
}

model DealerManualPurchaseItem {
  id           String   @id @default(cuid())
  productName  String
  type         InventoryItemType
  unit         String
  quantity     Decimal  @db.Decimal(10, 2)
  baseQuantity Decimal? @db.Decimal(10, 2)
  costPrice    Decimal  @db.Decimal(10, 2)
  sellingPrice Decimal  @db.Decimal(10, 2)
  totalAmount  Decimal  @db.Decimal(10, 2)

  purchaseId String
  purchase   DealerManualPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  // Link to DealerProduct created/updated
  dealerProductId String?
  dealerProduct   DealerProduct? @relation(fields: [dealerProductId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([purchaseId])
  @@index([dealerProductId])
}

model DealerManualCompanyPayment {
  id            String   @id @default(cuid())
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @default("CASH")
  paymentDate   DateTime @default(now())
  notes         String?
  reference     String?
  receiptUrl    String?

  // Balance snapshot after this payment
  balanceAfter Decimal @db.Decimal(10, 2)

  manualCompanyId String
  manualCompany   DealerManualCompany @relation(fields: [manualCompanyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([manualCompanyId, paymentDate])
}

// ==================== FARMER CART & PURCHASE REQUEST ====================

enum FarmerPurchaseRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model FarmerCart {
  id       String          @id @default(cuid())
  farmerId String
  farmer   User            @relation("FarmerCarts", fields: [farmerId], references: [id], onDelete: Cascade)
  dealerId String
  dealer   Dealer          @relation("DealerFarmerCarts", fields: [dealerId], references: [id], onDelete: Cascade)
  items    FarmerCartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmerId, dealerId])
  @@index([farmerId])
  @@index([dealerId])
}

model FarmerCartItem {
  id        String        @id @default(cuid())
  cartId    String
  cart      FarmerCart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   DealerProduct @relation("FarmerCartProducts", fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal       @db.Decimal(10, 2)
  unitPrice Decimal       @db.Decimal(10, 2)
  unit      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model FarmerPurchaseRequest {
  id              String                       @id @default(cuid())
  requestNumber   String                       @unique
  status          FarmerPurchaseRequestStatus   @default(PENDING)

  totalAmount     Decimal  @db.Decimal(10, 2)
  subtotalAmount  Decimal? @db.Decimal(10, 2)
  discountType    String?
  discountValue   Decimal? @db.Decimal(10, 2)

  notes           String?
  date            DateTime @default(now())

  reviewedAt      DateTime?
  rejectionReason String?

  farmerId   String
  farmer     User     @relation("FarmerPurchaseRequests", fields: [farmerId], references: [id], onDelete: Cascade)
  dealerId   String
  dealer     Dealer   @relation("DealerPurchaseRequests", fields: [dealerId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  dealerSaleId String?     @unique
  dealerSale   DealerSale? @relation(fields: [dealerSaleId], references: [id])

  items FarmerPurchaseRequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmerId, status])
  @@index([dealerId, status])
  @@index([customerId])
}

model FarmerPurchaseRequestItem {
  id           String   @id @default(cuid())
  quantity     Decimal  @db.Decimal(10, 2)
  unitPrice    Decimal  @db.Decimal(10, 2)
  totalAmount  Decimal  @db.Decimal(10, 2)
  unit         String?
  baseQuantity Decimal? @db.Decimal(10, 2)

  requestId String
  request   FarmerPurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId String
  product   DealerProduct         @relation("FarmerPurchaseRequestProducts", fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
  @@index([productId])
}

// ==================== UNIT CONVERSION MODELS ====================

model ProductUnitConversion {
  id               String   @id @default(cuid())
  unitName         String
  conversionFactor Decimal  @db.Decimal(10, 4)
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([productId, unitName])
  @@index([productId])
}

model DealerProductUnitConversion {
  id               String        @id @default(cuid())
  unitName         String
  conversionFactor Decimal       @db.Decimal(10, 4)
  dealerProductId  String
  dealerProduct    DealerProduct @relation(fields: [dealerProductId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([dealerProductId, unitName])
  @@index([dealerProductId])
}
