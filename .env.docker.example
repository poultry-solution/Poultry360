# PostgreSQL
POSTGRES_USER=poultry360
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=poultry360

# App
NODE_ENV=production
PORT=8081
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret
FRONTEND_URLS=https://yourdomain.com

# Seeding (set to "true" only on first deploy)
SEED_DATABASE=false

# Cloudflare R2
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET=

# Web Push (VAPID keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Docker Hub (for build/push script)
DOCKERHUB_USERNAME=
IMAGE_TAG=latest
