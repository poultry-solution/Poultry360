generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ---------- Enums ----------
enum Product {
  FEED
  MEDICINE
  EQUIPMENT
  CHICKS
}

enum Unit {
  PIECE
  KG
  LITER
}

/// ---------- Core Models ----------
model User {
  id       String   @id @default(cuid())
  email    String   @unique
  name     String
  phoneNo  String

  farms Farm[]

  addresses Address[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model Address {
  id        String  @id @default(cuid())
  houseNo   String?
  street    String?
  city      String
  state     String
  pinCode   String
  landmark  String?
  isPrimary Boolean @default(false)

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// ---------- Farm & Lots ----------
model Farm {
  id          String   @id @default(cuid())
  name        String
  lotCapacity Int
  lotSize     Int

  ownerId String
  owner   User @relation(fields: [ownerId], references: [id])

  lots FarmLot[]

  purchases InventoryPurchase[]
  consumptions InventoryConsumption[]
  sales Sale[]
  hatcherySupplies HatcherySupply[]
  mortalities Mortality[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  FarmPerformance FarmPerformance[]
}

model FarmLot {
  id        String  @id @default(cuid())
  lotNumber String
  capacity  Int
  size      Int

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  sales Sale[]
  consumptions InventoryConsumption[]
  hatcherySupplies HatcherySupply[]
  mortalities Mortality[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([farmId, lotNumber])
  @@index([farmId])
  LotPerformance LotPerformance[]
  vaccinations Vaccination[]
}

/// ---------- Hatchery (chicks supplier) ----------
model Hatchery {
  id        String @id @default(cuid())
  name      String
  location  String
  contactNo String

  supplierName String

  supplies HatcherySupply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HatcherySupply {
  id         String   @id @default(cuid())
  hatcheryId String
  hatchery   Hatchery @relation(fields: [hatcheryId], references: [id])

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  lotId  String?
  lot    FarmLot? @relation(fields: [lotId], references: [id])

  quantity Int
  unit     Unit    @default(PIECE)

  dateSupplied DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hatcheryId])
  @@index([farmId])
  @@index([lotId])
}

/// ---------- Dealers (inputs supplier) ----------
model Dealer {
  id        String @id @default(cuid())
  name      String
  location  String
  contactNo String

  dealerName String

  purchases InventoryPurchase[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ---------- Customers ----------
model Customer {
  id        String @id @default(cuid())
  name      String
  location  String
  contactNo String

  customerName String

  sales Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ---------- Inventory & Consumption ----------
model InventoryPurchase {
  id          String   @id @default(cuid())
  product     Product
  quantity    Int
  unit        Unit
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalAmount Decimal  @db.Decimal(14, 2)

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id])

  isPaidFull Boolean @default(false)
  paidAmount Decimal @default(0) @db.Decimal(12, 2)
  dueDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmId])
  @@index([dealerId])
  @@index([product])
  InventoryConsumption InventoryConsumption[]
}

model InventoryConsumption {
  id        String @id @default(cuid())
  product   Product
  quantity  Int
  unit      Unit

  lotId String
  lot   FarmLot @relation(fields: [lotId], references: [id])

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  purchaseId String?
  purchase   InventoryPurchase? @relation(fields: [purchaseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lotId])
  @@index([farmId])
  @@index([product])
  @@index([purchaseId])
}

/// ---------- Sales ----------
model Sale {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  amount    Decimal  @db.Decimal(12, 2)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  lotId String
  lot   FarmLot @relation(fields: [lotId], references: [id])

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([lotId])
  @@index([farmId])
}

/// ---------- Mortality Tracking ----------
model Mortality {
  id        String @id @default(cuid())
  date      DateTime @default(now())
  count     Int
  reason    String?

  lotId String
  lot   FarmLot @relation(fields: [lotId], references: [id])

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ---------- Analytics / Derived Tables ----------
model LotPerformance {
  id        String   @id @default(cuid())
  lotId String   @unique
  lot   FarmLot @relation(fields: [lotId], references: [id])

  totalChicks     Int
  mortalityCount  Int
  totalFeedUsed   Decimal  @db.Decimal(12,2)
  totalMedicine   Decimal  @db.Decimal(12,2)
  totalExpenses   Decimal  @db.Decimal(14,2)
  totalSales      Decimal  @db.Decimal(14,2)
  avgWeight       Decimal? @db.Decimal(6,2)
  fcr             Decimal? @db.Decimal(6,3)
  profit          Decimal  @db.Decimal(14,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FarmPerformance {
  id        String   @id @default(cuid())
  farmId String   @unique
  farm   Farm @relation(fields: [farmId], references: [id])

  totalLots       Int
  totalChicks     Int
  totalFeedUsed   Decimal @db.Decimal(14,2)
  totalMedicine   Decimal @db.Decimal(14,2)
  totalExpenses   Decimal @db.Decimal(14,2)
  totalSales      Decimal @db.Decimal(14,2)
  profit          Decimal @db.Decimal(14,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vaccination {
  id        String   @id @default(cuid())
  lotId     String
  lot       FarmLot @relation(fields: [lotId], references: [id])

  vaccine   String
  scheduledDate DateTime  // when the vaccination is planned
  completedDate DateTime? // when the vaccination was actually done
  status     VaccinationStatus @default(PENDING) // track status: pending/done/missed
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VaccinationStatus {
  PENDING
  SCHEDULED
  COMPLETED
  MISSED
}
